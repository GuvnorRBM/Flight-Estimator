<!doctype html>
<html lang="en-GB">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <title>Drone Flight Time Estimator</title>
  <style>
    :root { --gap: 12px; --radius: 12px; }
    body {
      font-family: system-ui, -apple-system, Segoe UI, Roboto, Arial, sans-serif;
      margin: 0;
      background: #0b0c10;
      color: #e8e8ea;
      line-height: 1.35;
    }
    header {
      padding: 18px 16px;
      background: #12131a;
      border-bottom: 1px solid rgba(255,255,255,0.08);
    }
    header h1 { margin: 0 0 6px 0; font-size: 18px; font-weight: 800; }
    header p { margin: 0; opacity: 0.9; font-size: 13px; }
    main { padding: 16px; max-width: 820px; margin: 0 auto; }
    .card {
      background: #12131a;
      border: 1px solid rgba(255,255,255,0.08);
      border-radius: var(--radius);
      padding: 14px;
      margin-bottom: 14px;
    }
    .grid { display: grid; gap: var(--gap); grid-template-columns: 1fr; }
    @media (min-width: 720px) { .grid.two { grid-template-columns: 1fr 1fr; } .grid.three { grid-template-columns: 1fr 1fr 1fr; } }
    label { display: block; font-size: 13px; margin-bottom: 6px; opacity: 0.9; }
    input[type="number"], select {
      width: 100%;
      padding: 12px;
      border-radius: 10px;
      border: 1px solid rgba(255,255,255,0.14);
      background: #0e0f14;
      color: #e8e8ea;
      outline: none;
      box-sizing: border-box;
    }
    input[type="checkbox"] { transform: scale(1.15); }
    .row { display: flex; gap: 10px; align-items: center; }
    .muted { opacity: 0.75; font-size: 12px; }
    .pill {
      display: inline-block;
      padding: 6px 10px;
      border-radius: 999px;
      background: rgba(255,255,255,0.08);
      border: 1px solid rgba(255,255,255,0.12);
      font-size: 12px;
      margin-right: 8px;
      margin-top: 6px;
    }
    .big { font-size: 22px; font-weight: 900; margin: 6px 0 10px 0; }
    table { width: 100%; border-collapse: collapse; margin-top: 10px; font-size: 13px; }
    th, td { padding: 10px 8px; border-bottom: 1px solid rgba(255,255,255,0.08); text-align: left; }
    th { opacity: 0.8; font-weight: 700; }
    .right { text-align: right; }
    .warn {
      margin-top: 10px;
      padding: 10px 12px;
      border-radius: 10px;
      border: 1px solid rgba(255, 195, 0, 0.25);
      background: rgba(255, 195, 0, 0.08);
      font-size: 12px;
      opacity: 0.98;
    }
    .stop {
      margin-top: 10px;
      padding: 12px;
      border-radius: 12px;
      border: 1px solid rgba(255, 80, 80, 0.35);
      background: rgba(255, 80, 80, 0.10);
      font-size: 13px;
      display: none;
    }
    button {
      width: 100%;
      padding: 12px;
      border-radius: 12px;
      border: 1px solid rgba(255,255,255,0.14);
      background: rgba(255,255,255,0.10);
      color: #e8e8ea;
      font-weight: 800;
      cursor: pointer;
    }
    button:hover { background: rgba(255,255,255,0.14); }
    code { font-family: ui-monospace, SFMono-Regular, Menlo, monospace; font-size: 12px; }
  </style>
</head>
<body>
  <header>
    <h1>Drone Flight Time Estimator</h1>
    <p><b>Flight-time estimator only.</b> This does not include pre-surveys, permissions, setup/take-down, on-site delays, or post-mission processing.</p>
  </header>

  <main>
    <div class="card">
      <div class="warn">
        Assumptions: Matrice 4DT, 60 m AGL, 9 m/s cruise, wide FOV 82°, lawnmower mapping, battery swaps add <b>15 mins</b> per <b>38 mins</b> airborne.
      </div>
    </div>

    <div class="card">
      <div class="grid two">
        <div>
          <label for="perimeter">Site perimeter</label>
          <div class="grid three" style="grid-template-columns: 2fr 1fr 1fr;">
            <input id="perimeter" type="number" min="0" step="0.01" placeholder="e.g. 2000" />
            <select id="perimeterUnit" aria-label="Perimeter unit">
              <option value="m">metres</option>
              <option value="km">kilometres</option>
            </select>
            <button type="button" id="exampleBtn">Example</button>
          </div>
          <div class="muted" style="margin-top:6px;">Perimeter drives the estimate. Area is derived using the selected shape.</div>
        </div>

        <div>
          <label for="shape">Perimeter type</label>
          <select id="shape">
            <option value="square" selected>Square (baseline)</option>
            <option value="circle">Circle (largest area)</option>
            <option value="rectangle">Rectangle (assumes 2:1)</option>
            <option value="complex">Complex (contact UAS)</option>
          </select>
          <div class="muted" style="margin-top:6px;">Rectangle assumes 2:1 aspect ratio. Complex sites need a proper look.</div>
        </div>
      </div>

      <div class="grid two" style="margin-top:12px;">
        <div>
          <label for="walkSpeed">RTK walk speed (m/s)</label>
          <input id="walkSpeed" type="number" min="0.5" step="0.1" value="1.4" />
          <div class="muted" style="margin-top:6px;">Default 1.4 m/s (about 5 km/h).</div>
        </div>

        <div>
          <label for="sidelap">2D sidelap (overlap)</label>
          <select id="sidelap">
            <option value="0.6">60%</option>
            <option value="0.7" selected>70% (default)</option>
            <option value="0.75">75%</option>
          </select>
          <div class="muted" style="margin-top:6px;">Used to calculate effective line spacing for mapping.</div>
        </div>
      </div>

      <div class="grid two" style="margin-top:12px;">
        <div>
          <label for="turnOverhead">Turn overhead</label>
          <select id="turnOverhead">
            <option value="1.05">Light (5%)</option>
            <option value="1.10" selected>Normal (10%)</option>
            <option value="1.15">Busy (15%)</option>
          </select>
          <div class="muted" style="margin-top:6px;">Adds time for turns, pauses, and line transitions.</div>
        </div>

        <div>
          <div class="row" style="margin-top: 22px;">
            <input id="includeBaseline" type="checkbox" checked />
            <label for="includeBaseline" style="margin:0;">Include baseline 2D mapping</label>
          </div>
          <div class="muted">Untick to estimate add-ons only.</div>
        </div>
      </div>

      <div class="stop" id="complexStop">
        <b>Complex site selected.</b><br />
        This estimator is not suitable for complex geometry (multiple compounds, voids, internal boundaries, tall obstructions, segmented work areas, etc).
        Please contact the <b>UAS Department</b> for a proper estimate and approach.
      </div>
    </div>

    <div class="card">
      <div class="grid two">
        <div>
          <div class="row">
            <input id="hiRes3d" type="checkbox" />
            <label for="hiRes3d" style="margin:0;">High res 3D mapping (adds 5× baseline 2D)</label>
          </div>
          <div class="muted">Additive to baseline.</div>
        </div>

        <div>
          <label for="thermalMode">Thermal requirement</label>
          <select id="thermalMode">
            <option value="none">None</option>
            <option value="basic">Basic thermal (adds 2× baseline 2D)</option>
            <option value="advanced">Advanced thermal (adds 8× baseline 2D)</option>
          </select>
          <div class="muted">Thermal is additive to baseline 2D.</div>
        </div>
      </div>

      <div class="grid two" style="margin-top:12px;">
        <div>
          <div class="row">
            <input id="hiResPano" type="checkbox" />
            <label for="hiResPano" style="margin:0;">High res panoramic</label>
          </div>
          <div class="muted">Perimeter flight time plus 5 stops of 3 mins.</div>
        </div>

        <div>
          <div class="row">
            <input id="hiResBuilding3d" type="checkbox" />
            <label for="hiResBuilding3d" style="margin:0;">High res 3D of a building</label>
          </div>
          <div class="muted">Adds 7.5× baseline 2D (3D plus extra 50%).</div>
        </div>
      </div>

      <div class="grid two" style="margin-top:12px;">
        <div>
          <div class="row">
            <input id="rtkWalk" type="checkbox" />
            <label for="rtkWalk" style="margin:0;">Surgery grade mapping (RTK walk)</label>
          </div>
          <div class="muted">Time to walk the perimeter (separate from airborne time).</div>
        </div>
      </div>

      <div class="warn">
        Battery swaps are counted as <code>floor(airborne_minutes / 38)</code> and charged at <b>15 mins</b> each.
      </div>
    </div>

    <div class="card" id="resultsCard" aria-live="polite">
      <div class="muted">Results</div>
      <div class="big" id="totalTime">Enter a perimeter to calculate</div>

      <div>
        <span class="pill" id="shapePill">Shape: square</span>
        <span class="pill" id="multPill">Multiplier: 1.000</span>
        <span class="pill" id="areaPill">Area: 0 m²</span>
      </div>

      <div>
        <span class="pill" id="airbornePill">Airborne: 0 mins</span>
        <span class="pill" id="swapPill">Swaps: 0 (0 mins)</span>
        <span class="pill" id="rtkPill">RTK walk: 0 mins</span>
      </div>

      <table>
        <thead>
          <tr>
            <th>Component</th>
            <th class="right">Time (mins)</th>
          </tr>
        </thead>
        <tbody id="breakdownBody"></tbody>
        <tfoot>
          <tr>
            <th>Total on-site time</th>
            <th class="right" id="totalMinsCell">0</th>
          </tr>
        </tfoot>
      </table>

      <div class="muted" style="margin-top:10px;">
        Reminder: flight-time estimate only, no pre-survey, setup/take-down, delays, or processing.
      </div>
    </div>
  </main>

  <script>
    // Fixed assumptions
    const ALT_M = 60;
    const FLIGHT_SPEED_MS = 9;
    const WIDE_FOV_DEG = 82;

    const SWAP_THRESHOLD_MIN = 38;
    const SWAP_ALLOWANCE_MIN = 15;

    const PANO_STOPS = 5;
    const PANO_STOP_MIN = 3;

    const $ = (id) => document.getElementById(id);
    const round1 = (x) => Math.round(x * 10) / 10;

    function clampNonNeg(x) { return isFinite(x) && x > 0 ? x : 0; }

    function perimeterToMetres(val, unit) {
      const v = clampNonNeg(val);
      return v * (unit === "km" ? 1000 : 1);
    }

    // Base square area from perimeter
    function areaSquareFromPerimeter(P) { return (P * P) / 16; }

    // Multipliers vs square for same perimeter
    // circle vs square = 4/pi
    const MULT_CIRCLE = 4 / Math.PI;     // ~1.273
    const MULT_SQUARE = 1.0;
    // rectangle assumes 2:1 aspect ratio -> area = P^2/18 -> multiplier 16/18 = 0.888...
    const MULT_RECT_2_TO_1 = 16 / 18;    // ~0.889

    function getShapeConfig(shape) {
      if (shape === "circle") return { label: "circle", multiplier: MULT_CIRCLE, note: "Largest area for a given perimeter" };
      if (shape === "rectangle") return { label: "rectangle (2:1)", multiplier: MULT_RECT_2_TO_1, note: "Assumes 2:1 aspect ratio" };
      return { label: "square", multiplier: MULT_SQUARE, note: "Baseline" };
    }

    function swathWidthM(altM, fovDeg) {
      const halfRad = (fovDeg * Math.PI / 180) / 2;
      return 2 * altM * Math.tan(halfRad);
    }

    function mappingMinutesFromArea(areaM2, sidelapFrac, turnOverheadFactor) {
      const side = Math.sqrt(areaM2); // equivalent square
      const swath = swathWidthM(ALT_M, WIDE_FOV_DEG);
      const spacing = swath * (1 - sidelapFrac);

      const lines = Math.max(1, Math.ceil(side / spacing));
      const pathM = (lines * side) * turnOverheadFactor;

      const seconds = pathM / FLIGHT_SPEED_MS;
      return seconds / 60;
    }

    function perimeterFlightMinutes(P) {
      const seconds = P / FLIGHT_SPEED_MS;
      return seconds / 60;
    }

    function setComplexMode(on) {
      $("complexStop").style.display = on ? "block" : "none";
      $("resultsCard").style.opacity = on ? "0.45" : "1";
      $("resultsCard").style.pointerEvents = on ? "none" : "auto";
    }

    function renderEmpty() {
      $("totalTime").textContent = "Enter a perimeter to calculate";
      $("shapePill").textContent = "Shape: -";
      $("multPill").textContent = "Multiplier: -";
      $("areaPill").textContent = "Area: 0 m²";
      $("airbornePill").textContent = "Airborne: 0 mins";
      $("swapPill").textContent = "Swaps: 0 (0 mins)";
      $("rtkPill").textContent = "RTK walk: 0 mins";
      $("breakdownBody").innerHTML = "";
      $("totalMinsCell").textContent = "0";
    }

    function renderResults(shapeLabel, mult, areaM2, components, airborneMins, swaps, swapMins, rtkMins, totalOnSiteMins) {
      $("shapePill").textContent = `Shape: ${shapeLabel}`;
      $("multPill").textContent = `Multiplier: ${mult.toFixed(3)}`;
      $("areaPill").textContent = `Area: ${Math.round(areaM2).toLocaleString("en-GB")} m²`;

      $("totalTime").textContent = `${round1(totalOnSiteMins)} mins total on-site time`;
      $("airbornePill").textContent = `Airborne: ${round1(airborneMins)} mins`;
      $("swapPill").textContent = `Swaps: ${swaps} (${round1(swapMins)} mins)`;
      $("rtkPill").textContent = `RTK walk: ${round1(rtkMins)} mins`;

      const tbody = $("breakdownBody");
      tbody.innerHTML = "";

      components.forEach(c => {
        const tr = document.createElement("tr");
        const td1 = document.createElement("td");
        const td2 = document.createElement("td");
        td1.textContent = c.name;
        td2.textContent = round1(c.mins).toString();
        td2.className = "right";
        tr.appendChild(td1);
        tr.appendChild(td2);
        tbody.appendChild(tr);
      });

      const trSwap = document.createElement("tr");
      const tdS1 = document.createElement("td");
      const tdS2 = document.createElement("td");
      tdS1.textContent = "Battery swap allowance";
      tdS2.textContent = round1(swapMins).toString();
      tdS2.className = "right";
      trSwap.appendChild(tdS1);
      trSwap.appendChild(tdS2);
      tbody.appendChild(trSwap);

      $("totalMinsCell").textContent = round1(totalOnSiteMins).toString();
    }

    function calc() {
      const shape = $("shape").value;

      // Complex mode: stop, don’t pretend
      if (shape === "complex") {
        setComplexMode(true);
        return;
      }
      setComplexMode(false);

      const perVal = parseFloat($("perimeter").value);
      const unit = $("perimeterUnit").value;

      const walkSpeed = clampNonNeg(parseFloat($("walkSpeed").value)) || 1.4;
      const sidelap = parseFloat($("sidelap").value);
      const turnOverhead = parseFloat($("turnOverhead").value);

      const includeBaseline = $("includeBaseline").checked;
      const hiRes3d = $("hiRes3d").checked;
      const thermalMode = $("thermalMode").value;
      const hiResPano = $("hiResPano").checked;
      const hiResBuilding3d = $("hiResBuilding3d").checked;
      const rtkWalk = $("rtkWalk").checked;

      const P = perimeterToMetres(perVal, unit);
      if (!P) { renderEmpty(); return; }

      const cfg = getShapeConfig(shape);
      const baseSquareArea = areaSquareFromPerimeter(P);
      const areaM2 = baseSquareArea * cfg.multiplier;

      const base2DMin = mappingMinutesFromArea(areaM2, sidelap, turnOverhead);

      const components = [];

      if (includeBaseline) components.push({ name: "Baseline 2D mapping (area-based)", mins: base2DMin, airborne: true });
      if (hiRes3d) components.push({ name: "High res 3D mapping (adds 5× baseline 2D)", mins: base2DMin * 5, airborne: true });

      if (thermalMode === "basic") components.push({ name: "Basic thermal (adds 2× baseline 2D)", mins: base2DMin * 2, airborne: true });
      if (thermalMode === "advanced") components.push({ name: "Advanced thermal (adds 8× baseline 2D)", mins: base2DMin * 8, airborne: true });

      if (hiResBuilding3d) components.push({ name: "High res building 3D (adds 7.5× baseline 2D)", mins: base2DMin * 7.5, airborne: true });

      if (hiResPano) {
        const panoMin = perimeterFlightMinutes(P) + (PANO_STOPS * PANO_STOP_MIN);
        components.push({ name: `High res panoramic (perimeter + ${PANO_STOPS} stops)`, mins: panoMin, airborne: true });
      }

      const airborneMins = components.filter(c => c.airborne).reduce((a, c) => a + c.mins, 0);
      const swaps = Math.floor(airborneMins / SWAP_THRESHOLD_MIN);
      const swapMins = swaps * SWAP_ALLOWANCE_MIN;

      let rtkMins = 0;
      if (rtkWalk) {
        rtkMins = (P / walkSpeed) / 60;
        components.push({ name: `RTK perimeter walk (@ ${walkSpeed} m/s)`, mins: rtkMins, airborne: false });
      }

      const totalOnSiteMins = airborneMins + swapMins + rtkMins;

      renderResults(cfg.label, cfg.multiplier, areaM2, components, airborneMins, swaps, swapMins, rtkMins, totalOnSiteMins);
    }

    // Wire up events
    ["perimeter","perimeterUnit","shape","walkSpeed","sidelap","turnOverhead","includeBaseline","hiRes3d","thermalMode","hiResPano","hiResBuilding3d","rtkWalk"]
      .forEach(id => $(id).addEventListener("input", calc));

    $("exampleBtn").addEventListener("click", () => {
      $("perimeter").value = 2400;
      $("perimeterUnit").value = "m";
      $("shape").value = "circle";
      $("walkSpeed").value = 1.4;
      $("sidelap").value = "0.7";
      $("turnOverhead").value = "1.10";
      $("includeBaseline").checked = true;
      $("hiRes3d").checked = true;
      $("thermalMode").value = "basic";
      $("hiResPano").checked = true;
      $("hiResBuilding3d").checked = false;
      $("rtkWalk").checked = true;
      calc();
    });

    // Initial
    renderEmpty();
    calc();
  </script>
</body>
</html>
